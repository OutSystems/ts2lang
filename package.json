{
  "name": "@outsystems/ts2lang",
  "version": "1.0.21",
  "description": "TypeScript to (language) bindings generator",
  "main": "ts2lang.js",
  "bin": {
    "ts2lang": "ts2lang-main.js"
  },
  "scripts": {
    "build": "tsc -p src",
    "test": "npm run build && node dist/ts2lang-main --file test/ts2lang.json",
    "go": "npm run build && node dist/ts2lang-main",
    "pack": "rimraf dist && npm run build && cpy package.json dist && cd dist && npm pack && cpy *.tgz .. && cd .."
  },
  "author": "OutSystems",
  "license": "ISC",
  "repository": "OutSystems/ts2lang",
  "preferGlobal": true,
  "dependencies": {
    "@outsystems/ts2lang": "^1.0.12",
    "commander": "^2.9.0",
    "glob": "^7.1.2",
    "is-directory": "^0.3.1",
    "merge": "^1.2.0",
    "typescript": "3.4"
  },
  "devDependencies": {
    "@types/commander": "^2.3.31",
    "@types/glob": "^5.0.35",
    "@types/node": "^6.0.55",
    "cpy-cli": "^3.1.1",
    "rimraf": "^3.0.2"
  }
}
